{
  "name": "aperant-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aperant — Turkish real-estate marketplace admin panel (frontend-only, Phase 1)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome check ./src ./tests",
    "format": "biome format --write ./src ./tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "msw:init": "msw init public/ --save"
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.0",
    "@tanstack/query-core": "^5.60.0",
    "alpinejs": "^3.14.0",
    "apexcharts": "^3.54.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.0",
    "flowbite": "^2.5.0",
    "gridjs": "^6.2.0",
    "i18next": "^23.16.0",
    "navigo": "^8.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.0",
    "autoprefixer": "^10.4.0",
    "happy-dom": "^15.0.0",
    "msw": "^2.6.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "msw": {
    "workerDirectory": ["public"]
  }
}
