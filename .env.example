# Aperant Admin Panel — Environment Configuration
# Copy to `.env` for local development. DO NOT commit `.env` itself.

# Base URL for API calls. When VITE_USE_MOCKS=true, MSW intercepts these.
VITE_API_BASE_URL=http://localhost:5173/api/v1

# Enable MSW (Mock Service Worker) interception. Set to 'false' to hit real backend.
VITE_USE_MOCKS=true

# App version (displayed in footer). Leave blank to use package.json version at build time.
VITE_APP_VERSION=
